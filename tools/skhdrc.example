# Example skhdrc entry to bind Cmd+Ctrl+Shift+M to dictation mute/unmute.
# Install skhd (brew install skhd) and place this in ~/.skhdrc, then run
# `skhd --start-service` (skhd runs as a persistent background service,
# unlike xbindkeys which this repo's supervisor.sh launches per-run).
#
# On macOS, ./main does not start an HTTP control server; it writes its
# PID to /tmp/simon-dictate.pid and toggles dictation on/off when it
# receives SIGUSR1. This binding sends that signal directly.

cmd + ctrl + shift - m : kill -SIGUSR1 $(cat /tmp/simon-dictate.pid)
